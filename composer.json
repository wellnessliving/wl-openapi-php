{
    "name": "wellnessliving/wl-sdk-php",
    "description": "WellnessLiving PHP SDK - auto-generated from OpenAPI spec",
    "license": "MIT",
    "require": {
        "php": ">=7.4",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "symfony/yaml": "^6.4|^7.0"
    },
    "autoload": {
        "psr-4": {
            "WlSdk\\": "stable/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WlSdk\\": "dev/src/"
        }
    },
    "scripts": {
        "generate": "php scripts/generate.php",
        "generate:stable": "php scripts/generate.php stable",
        "generate:dev": "php scripts/generate.php dev"
    }
}
