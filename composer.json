{
    "name": "wellnessliving/wl-openapi-php",
    "description": "WellnessLiving PHP SDK - production channel",
    "license": "MIT",
    "require": {
        "php": ">=7.4",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "symfony/yaml": "^6.4|^7.0"
    },
    "autoload": {
        "psr-4": {
            "WlSdk\\": "src/"
        }
    },
    "scripts": {
        "generate": "php scripts/generate.php",
        "generate:dev": "php scripts/generate.php dev",
        "generate:production": "php scripts/generate.php production",
        "generate:stable": "php scripts/generate.php stable"
    }
}
